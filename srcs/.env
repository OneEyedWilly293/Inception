# ── Domain ────────────────────────────────────────────────────────────
DOMAIN_NAME=jgueon.42.fr

# ── NGINX ports ───────────────────────────────────────────────────────
# NGINX_HTTP_PORT       = the port nginx listens on INSIDE the container
# NGINX_HTTP_PORT_HOST  = the port exposed to the HOST machine
# They are the same here (80:80 and 443:443) but can differ if needed
NGINX_HTTP_PORT=80
NGINX_HTTP_PORT_HOST=80
NGINX_HTTPS_PORT=443
NGINX_HTTPS_PORT_HOST=443

# ── PHP-FPM ───────────────────────────────────────────────────────────
# The port WordPress's PHP-FPM listens on inside the Docker network
# NGINX forwards all .php requests to wordpress:9000
PHP_FPM_PORT=9000

# ── MariaDB ───────────────────────────────────────────────────────────
# Standard MySQL/MariaDB port
MARIADB_PORT=3306
# 0.0.0.0 = accept connections from any IP on the Docker network
# (safe because the network is private/internal)
MARIADB_BIND_ADDRESS=0.0.0.0

# ── WordPress ─────────────────────────────────────────────────────────
# The title shown at the top of your WordPress site
WORDPRESS_TITLE=jgueon_title

# ── User ──────────────────────────────────────────────────────────────
# ${USER} is your Linux username — used to build the volume paths:
# /home/yourlogin/data/wordpress and /home/yourlogin/data/mariadb
LOGIN=${USER}
